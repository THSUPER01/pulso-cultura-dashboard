// =====================================================================
// FAVORABILITY BY QUESTION
// =====================================================================
function updateFavByQuestion() {
    destroyChart('favPregunta');
    const questions = DASHBOARD_DATA.questions;
    const labels = questions.map((q, i) => 'P' + (i + 1));
    const favData = [], indData = [], desfData = [];

    questions.forEach(q => {
        const f = calcFavForQuestions(filteredRecords, [q.key]);
        favData.push(f.fav);
        indData.push(f.ind);
        desfData.push(f.desf);
    });

    const ctx = document.getElementById('chartFavPregunta').getContext('2d');

    charts.favPregunta = new Chart(ctx, {
        type: 'bar',
        data: {
            labels,
            datasets: [
                {
                    label: 'Favorable',
                    data: favData,
                    backgroundColor: COLORS.favorable,
                    borderRadius: 4,
                },
                {
                    label: 'Indeciso',
                    data: indData,
                    backgroundColor: COLORS.indeciso,
                    borderRadius: 4,
                },
                {
                    label: 'Desfavorable',
                    data: desfData,
                    backgroundColor: COLORS.desfavorable,
                    borderRadius: 4,
                },
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: true, position: 'top' },
                datalabels: {
                    anchor: 'end', align: 'end',
                    font: { weight: 'bold', size: 9 },
                    color: '#333',
                    formatter: v => v > 0 ? v.toFixed(1) + '%' : '',
                },
                tooltip: {
                    callbacks: {
                        title: function(items) {
                            const idx = items[0].dataIndex;
                            return questions[idx].text;
                        }
                    }
                },
            },
            scales: {
                y: { beginAtZero: true, max: 100, ticks: { callback: v => v + '%' } },
                x: {
                    ticks: {
                        callback: function(value, index) {
                            return labels[index];
                        },
                        font: { size: 10 },
                    },
                },
            },
        },
        plugins: [{
            afterDraw: function(chart) {
                // Draw question short text under P labels
                const xAxis = chart.scales.x;
                const ctx2 = chart.ctx;
                ctx2.save();
                ctx2.font = '9px sans-serif';
                ctx2.fillStyle = '#666';
                ctx2.textAlign = 'center';
                xAxis.ticks.forEach((tick, i) => {
                    const x = xAxis.getPixelForTick(i);
                    const txt = shortLabel(questions[i].text, 30);
                    // wrap text
                    const words = txt.split(' ');
                    let lines = [], line = '';
                    words.forEach(w => {
                        if ((line + ' ' + w).length > 18) { lines.push(line); line = w; }
                        else line = line ? line + ' ' + w : w;
                    });
                    if (line) lines.push(line);
                    lines.slice(0, 3).forEach((l, li) => {
                        ctx2.fillText(l, x, chart.height - 5 + (li * 10));
                    });
                });
                ctx2.restore();
            }
        }],
    });
}

