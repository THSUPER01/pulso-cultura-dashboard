<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pulso Cultura - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --favorable: #28a745;
            --indeciso: #ffc107;
            --desfavorable: #dc3545;
            --femenino: #FFB6C1;
            --masculino: #6CA6CD;
            --bg-body: #f0f2f5;
            --card-shadow: 0 2px 8px rgba(0,0,0,0.08);
            --text-main: #24324a;
            --text-muted: #64748b;
            --border-soft: #e2e8f0;
            --panel-soft: #f8f9fd;
        }
        * { box-sizing: border-box; }
        body { background: var(--bg-body); font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; color: var(--text-main); min-width: 320px; }
        .dashboard-header {
            background: linear-gradient(135deg, #1a237e 0%, #283593 100%);
            color: #fff; padding: 1.2rem 0; margin-bottom: 1.5rem;
        }
        .header-inner { display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
        .header-copy { min-width: 0; }
        .header-actions { flex-shrink: 0; }
        .dashboard-header h1 { font-size: 1.6rem; font-weight: 700; margin: 0; }
        .dashboard-header .subtitle { opacity: 0.85; font-size: 0.9rem; }
        .card { border: none; border-radius: 12px; box-shadow: var(--card-shadow); margin-bottom: 1.2rem; }
        .card-header { background: #fff; border-bottom: 2px solid #e9ecef; border-radius: 12px 12px 0 0 !important; font-weight: 600; }
        .section-title { font-size: 1.1rem; font-weight: 700; color: #1a237e; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 3px solid #1a237e; }
        .kpi-card { text-align: center; padding: 1.5rem; }
        .kpi-number { font-size: 3rem; font-weight: 800; color: #1a237e; }
        .kpi-label { font-size: 0.95rem; color: #6c757d; margin-top: 0.3rem; }
        .filter-section { background: #fff; border-radius: 12px; padding: 1rem 1.2rem; }
        .filter-label { font-size: 0.8rem; font-weight: 600; color: #495057; margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .form-select { border-radius: 8px; border-color: #dee2e6; font-size: 0.875rem; }
        .form-select:focus { border-color: #1a237e; box-shadow: 0 0 0 0.2rem rgba(26,35,126,0.15); }
        .chart-container { position: relative; width: 100%; min-height: 240px; }
        .chart-container canvas { width: 100% !important; height: 100% !important; }
        .chart-container.chart-sm { min-height: 220px; }
        .chart-container.chart-md { min-height: 300px; }
        .chart-container.chart-lg { min-height: 380px; }
        .chart-container.chart-xl { min-height: 500px; }
        .chart-container.pie { min-height: 250px; max-width: 300px; margin: 0 auto; }
        .pie-panel { display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
        .pie-stats { min-width: 200px; }
        .pie-stat-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            background: var(--panel-soft);
            border: 1px solid var(--border-soft);
            border-radius: 10px;
            padding: 0.65rem 0.8rem;
            margin-bottom: 0.6rem;
            color: var(--text-main);
        }
        .pie-stat-item:last-child { margin-bottom: 0; }
        .pie-stat-label { font-size: 0.85rem; color: var(--text-muted); }
        .pie-stat-value { font-size: 1rem; font-weight: 700; }
        .chart-scroll {
            width: 100%;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 0.35rem;
        }
        .chart-scroll .chart-container {
            min-width: 100%;
        }
        .btn-export { background: #1a237e; border: none; font-size: 0.85rem; border-radius: 8px; }
        .btn-export:hover { background: #283593; }
        .btn-clear { font-size: 0.85rem; border-radius: 8px; }
        .detail-table { font-size: 0.82rem; }
        .detail-table th { background: #1a237e; color: #fff; font-weight: 600; position: sticky; top: 0; }
        .detail-table td { vertical-align: middle; }
        .mini-bar-container { display: flex; height: 22px; border-radius: 4px; overflow: hidden; min-width: 150px; }
        .mini-bar { display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.7rem; font-weight: 600; }
        .filter-divider { border-left: 2px solid #dee2e6; }
        .table-responsive { -webkit-overflow-scrolling: touch; }
        @media (max-width: 991.98px) {
            .header-inner { flex-direction: column; align-items: stretch; }
            .header-actions { width: 100%; }
            .btn-export { width: 100%; }
            .container-fluid.px-4 { padding-left: 1rem !important; padding-right: 1rem !important; }
        }
        @media (max-width: 768px) {
            .filter-divider { border-left: none; border-top: 2px solid #dee2e6; padding-top: 1rem; margin-top: 1rem; }
            .kpi-number { font-size: 2.2rem; }
            .section-title { font-size: 1rem; }
            .card-header { font-size: 0.95rem; }
            .chart-container.chart-sm { min-height: 210px; }
            .chart-container.chart-md { min-height: 260px; }
            .chart-container.chart-lg { min-height: 340px; }
            .chart-container.chart-xl { min-height: 460px; }
            .chart-container.pie { max-width: none; min-height: 230px; }
            .pie-panel { flex-direction: column; align-items: stretch; }
            .pie-stats { min-width: 0; width: 100%; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.65rem; }
            .pie-stat-item { margin-bottom: 0; min-height: 72px; }
            .detail-table { font-size: 0.76rem; }
            .mini-bar-container { min-width: 120px; }
        }
        @media (max-width: 575.98px) {
            .dashboard-header h1 { font-size: 1.2rem; }
            .dashboard-header .subtitle { font-size: 0.8rem; }
            .pie-stats { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<!-- Header -->
<div class="dashboard-header">
    <div class="container-fluid px-4">
        <div class="header-inner">
            <div class="header-copy">
                <h1><i class="bi bi-bar-chart-fill me-2"></i>Pulso Cultura - Dashboard de Resultados</h1>
                <div class="subtitle">Super de Alimentos S.A. | Encuesta de Clima Organizacional</div>
            </div>
            <div class="header-actions">
                <button class="btn btn-light btn-export" onclick="exportCSV()">
                    <i class="bi bi-download me-1"></i> Exportar CSV
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid px-4">

    <!-- FILTERS -->
    <div class="card mb-4">
        <div class="card-header d-flex align-items-center">
            <i class="bi bi-funnel-fill me-2 text-primary"></i> Filtros
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Demographic Filters -->
                <div class="col-lg-7">
                    <div class="mb-2" style="font-size:0.85rem;font-weight:700;color:#1a237e;">
                        <i class="bi bi-people-fill me-1"></i> Filtros Demograficos
                    </div>
                    <div class="row g-2">
                        <div class="col-md-3">
                            <div class="filter-label">Genero</div>
                            <select id="filterGenero" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <div class="filter-label">Edad</div>
                            <select id="filterEdad" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <div class="filter-label">Antiguedad</div>
                            <select id="filterAntiguedad" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <div class="filter-label">Estudios Cursados</div>
                            <select id="filterEstudios" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                    </div>
                </div>
                <!-- Area Filters -->
                <div class="col-lg-4 filter-divider ps-lg-4">
                    <div class="mb-2" style="font-size:0.85rem;font-weight:700;color:#1a237e;">
                        <i class="bi bi-building me-1"></i> Filtros de Area
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="filter-label">Centro</div>
                            <select id="filterCentro" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <div class="filter-label">Planta</div>
                            <select id="filterPlanta" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                    </div>
                </div>
                <!-- Clear button -->
                <div class="col-lg-1 d-flex align-items-end justify-content-end mt-3 mt-lg-0">
                    <button class="btn btn-outline-secondary btn-clear btn-sm w-100" onclick="clearFilters()">
                        <i class="bi bi-x-circle me-1"></i>Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI + PIE -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body kpi-card">
                    <div class="kpi-label"><i class="bi bi-person-check-fill me-1"></i>Total de Encuestados</div>
                    <div class="kpi-number" id="totalEncuestados">0</div>
                    <div class="text-muted" style="font-size:0.8rem;" id="totalSubtext"></div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-pie-chart-fill me-2 text-success"></i>Favorabilidad Global</div>
                <div class="card-body pie-panel">
                    <div class="chart-container pie">
                        <canvas id="chartPie"></canvas>
                    </div>
                    <div id="pieStats" class="pie-stats"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- SOCIODEMOGRAPHIC -->
    <div class="section-title"><i class="bi bi-person-vcard me-2"></i>Caracterizacion Sociodemografica</div>
    <div class="row mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Genero</div>
                <div class="card-body"><div class="chart-container chart-sm"><canvas id="chartGenero"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Edad</div>
                <div class="card-body"><div class="chart-container chart-sm"><canvas id="chartEdad"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Antiguedad</div>
                <div class="card-body"><div class="chart-container chart-sm"><canvas id="chartAntiguedad"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Estudios Cursados</div>
                <div class="card-body"><div class="chart-container chart-sm"><canvas id="chartEstudios"></canvas></div></div>
            </div>
        </div>
    </div>

    <!-- SURVEY RESULTS -->
    <div class="section-title"><i class="bi bi-clipboard-data me-2"></i>Resultados de Encuesta</div>

    <!-- Favorability by Question -->
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-bar-chart-steps me-2 text-success"></i>Favorabilidad por Pregunta</div>
        <div class="card-body">
            <div class="chart-scroll">
                <div class="chart-container chart-xl" id="chartFavPreguntaWrapper"><canvas id="chartFavPregunta"></canvas></div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-building me-2 text-primary"></i>Favorabilidad por Centro</div>
                <div class="card-body"><div class="chart-container chart-md"><canvas id="chartFavCentro"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-diagram-3 me-2 text-info"></i>Favorabilidad por Planta</div>
                <div class="card-body"><div class="chart-container chart-md"><canvas id="chartFavPlanta"></canvas></div></div>
            </div>
        </div>
    </div>

    <!-- DIMENSION & VARIABLE ANALYSIS -->
    <div class="section-title"><i class="bi bi-diagram-2 me-2"></i>Analisis por Dimension y Variable</div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-layers me-2 text-warning"></i>Favorabilidad por Dimension</div>
                <div class="card-body"><div class="chart-container chart-md"><canvas id="chartFavDimension"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-tags me-2 text-danger"></i>Favorabilidad por Variable</div>
                <div class="card-body"><div class="chart-container chart-md"><canvas id="chartFavVariable"></canvas></div></div>
            </div>
        </div>
    </div>

    <!-- Detail Table -->
    <div class="card mb-5">
        <div class="card-header"><i class="bi bi-table me-2 text-secondary"></i>Tabla Detallada: Dimension / Variable / Pregunta</div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height:600px;overflow-y:auto;">
                <table class="table table-hover detail-table mb-0">
                    <thead>
                        <tr>
                            <th>Dimension</th>
                            <th>Variable</th>
                            <th>Pregunta</th>
                            <th style="min-width:100px;">Favorable</th>
                            <th style="min-width:100px;">Indeciso</th>
                            <th style="min-width:100px;">Desfavorable</th>
                            <th style="min-width:200px;">Distribucion</th>
                        </tr>
                    </thead>
                    <tbody id="detailTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<!-- CDN Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
// =====================================================================
// DATA (embedded by Python)
// =====================================================================
const DASHBOARD_DATA = {{ dashboard_data_json }};

// =====================================================================
// GLOBALS
// =====================================================================
const COLORS = {
    favorable: '#28a745',
    indeciso: '#ffc107',
    desfavorable: '#dc3545',
    femenino: '#FFB6C1',
    masculino: '#6CA6CD',
};

const BREAKPOINTS = {
    mobile: 576,
    desktop: 992,
};

let charts = {};
let filteredRecords = [];
let currentViewportBucket = getViewportBucket();

// =====================================================================
// INIT
// =====================================================================
document.addEventListener('DOMContentLoaded', () => {
    Chart.register(ChartDataLabels);
    Chart.defaults.animation = false;
    Chart.defaults.font.family = "'Segoe UI', system-ui, -apple-system, sans-serif";
    Chart.defaults.color = '#475569';
    Chart.defaults.plugins.legend.labels.usePointStyle = true;
    Chart.defaults.plugins.legend.labels.boxWidth = 10;
    Chart.defaults.elements.bar.borderSkipped = false;
    populateFilters();
    applyFilters();
});

function populateFilters() {
    const opts = DASHBOARD_DATA.filterOptions;
    fillSelect('filterGenero', opts.genero);
    fillSelect('filterEdad', opts.edad);
    fillSelect('filterAntiguedad', opts.antiguedad);
    fillSelect('filterEstudios', opts.estudios);
    fillSelect('filterCentro', opts.centro);
    fillSelect('filterPlanta', opts.planta);
}

function fillSelect(id, values) {
    const sel = document.getElementById(id);
    values.forEach(v => {
        const opt = document.createElement('option');
        opt.value = v;
        opt.textContent = v;
        sel.appendChild(opt);
    });
}

// =====================================================================
// FILTERS
// =====================================================================
function applyFilters() {
    const gf = document.getElementById('filterGenero').value;
    const ef = document.getElementById('filterEdad').value;
    const af = document.getElementById('filterAntiguedad').value;
    const esf = document.getElementById('filterEstudios').value;
    const cf = document.getElementById('filterCentro').value;
    const pf = document.getElementById('filterPlanta').value;

    filteredRecords = DASHBOARD_DATA.records.filter(r => {
        if (gf && r.genero !== gf) return false;
        if (ef && r.edad !== ef) return false;
        if (af && r.antiguedad !== af) return false;
        if (esf && r.estudios !== esf) return false;
        if (cf && r.centro !== cf) return false;
        if (pf && r.planta !== pf) return false;
        return true;
    });

    updateAll();
}

function clearFilters() {
    ['filterGenero','filterEdad','filterAntiguedad','filterEstudios','filterCentro','filterPlanta']
        .forEach(id => document.getElementById(id).value = '');
    applyFilters();
}

// =====================================================================
// UPDATE ALL
// =====================================================================
function updateAll() {
    updateTotalCard();
    updatePieChart();
    updateGenderChart();
    updateAgeChart();
    updateSeniorityChart();
    updateEducationChart();
    updateFavByQuestion();
    updateFavByCentro();
    updateFavByPlanta();
    updateFavByDimension();
    updateFavByVariable();
    updateDetailTable();
}

// =====================================================================
// HELPERS
// =====================================================================
function destroyChart(key) {
    if (charts[key]) { charts[key].destroy(); charts[key] = null; }
}

function countByGroup(records, field) {
    const counts = {};
    records.forEach(r => {
        const val = r[field] || 'Sin dato';
        counts[val] = (counts[val] || 0) + 1;
    });
    return counts;
}

function countByGroupGender(records, field, orderedKeys) {
    const fem = {}, masc = {};
    orderedKeys.forEach(k => { fem[k] = 0; masc[k] = 0; });
    records.forEach(r => {
        const val = r[field] || 'Sin dato';
        if (!orderedKeys.includes(val)) return;
        if (r.genero === 'Femenino') fem[val]++;
        else if (r.genero === 'Masculino') masc[val]++;
    });
    return { fem, masc };
}

function calcFavorability(records) {
    let total = 0, fav = 0, ind = 0, desf = 0;
    const qKeys = DASHBOARD_DATA.questions.map(q => q.key);
    records.forEach(r => {
        qKeys.forEach(k => {
            const v = r[k];
            if (v === 1 || v === 2 || v === 3) {
                total++;
                if (v === 3) fav++;
                else if (v === 2) ind++;
                else desf++;
            }
        });
    });
    if (total === 0) return { fav: 0, ind: 0, desf: 0, total: 0 };
    return {
        fav: (fav / total * 100),
        ind: (ind / total * 100),
        desf: (desf / total * 100),
        total,
    };
}

function calcFavForQuestions(records, questionKeys) {
    let total = 0, fav = 0, ind = 0, desf = 0;
    records.forEach(r => {
        questionKeys.forEach(k => {
            const v = r[k];
            if (v === 1 || v === 2 || v === 3) {
                total++;
                if (v === 3) fav++;
                else if (v === 2) ind++;
                else desf++;
            }
        });
    });
    if (total === 0) return { fav: 0, ind: 0, desf: 0 };
    return {
        fav: (fav / total * 100),
        ind: (ind / total * 100),
        desf: (desf / total * 100),
    };
}

function shortLabel(text, maxLen = 40) {
    if (text.length <= maxLen) return text;
    return text.substring(0, maxLen - 3) + '...';
}

function escapeHtml(value) {
    return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function wrapLabel(text, maxLineLength = 18, maxLines = 2) {
    const truncated = shortLabel(String(text), maxLineLength * maxLines + 10);
    const words = truncated.split(/\s+/).filter(Boolean);
    const lines = [];
    let line = '';

    words.forEach(word => {
        const nextLine = line ? `${line} ${word}` : word;
        if (nextLine.length > maxLineLength && line) {
            lines.push(line);
            line = word;
        } else {
            line = nextLine;
        }
    });

    if (line) lines.push(line);
    return lines.slice(0, maxLines);
}

function getViewportBucket() {
    if (window.innerWidth < BREAKPOINTS.mobile) return 'mobile';
    if (window.innerWidth < BREAKPOINTS.desktop) return 'tablet';
    return 'desktop';
}

function isMobileScreen() {
    return currentViewportBucket === 'mobile';
}

function isCompactScreen() {
    return currentViewportBucket !== 'desktop';
}

function getFixedChartHeight(size) {
    const heights = {
        pie: { desktop: 250, tablet: 240, mobile: 220 },
        sm: { desktop: 220, tablet: 215, mobile: 200 },
        md: { desktop: 300, tablet: 280, mobile: 260 },
    };
    return heights[size][currentViewportBucket];
}

function getLongChartHeight(categoryCount, baseHeight = 120, rowHeight = 26) {
    const adjustedRowHeight = isMobileScreen() ? rowHeight + 8 : rowHeight;
    return Math.max(baseHeight, baseHeight + (categoryCount * adjustedRowHeight));
}

function setChartHeight(canvasId, height) {
    const canvas = document.getElementById(canvasId);
    if (!canvas || !canvas.parentElement) return;
    canvas.parentElement.style.height = `${height}px`;
}

function setChartWidth(containerId, width) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.style.width = typeof width === 'number' ? `${width}px` : width;
}

function getLegendOptions(position = 'top') {
    return {
        display: true,
        position,
        labels: {
            font: { size: isMobileScreen() ? 10 : 11 },
            padding: isMobileScreen() ? 10 : 14,
        },
    };
}

function getDataLabelOptions({ percent = false, decimals = 1, minValue = 0, categoryCount = 0, forceDisplay = false, horizontal = false }) {
    const shouldDisplay = forceDisplay || (!isMobileScreen() && categoryCount <= 6);
    return {
        display: shouldDisplay,
        anchor: 'end',
        align: horizontal ? 'right' : 'end',
        clamp: true,
        clip: false,
        color: '#334155',
        font: { weight: 'bold', size: isCompactScreen() ? 9 : 10 },
        formatter: value => {
            const numericValue = Number(value) || 0;
            if (numericValue <= minValue) return '';
            return percent ? `${numericValue.toFixed(decimals)}%` : `${Math.round(numericValue)}`;
        },
    };
}

function getBarScales({ percent = false, horizontal = false }) {
    const valueScale = {
        beginAtZero: true,
        grid: { color: 'rgba(15, 23, 42, 0.08)' },
        ticks: {
            color: '#64748b',
            font: { size: isMobileScreen() ? 9 : 11 },
        },
    };

    if (percent) {
        valueScale.max = 100;
        valueScale.ticks.callback = value => `${value}%`;
    } else {
        valueScale.ticks.precision = 0;
    }

    const categoryScale = {
        grid: { display: false },
        ticks: {
            color: '#334155',
            autoSkip: false,
            font: { size: isMobileScreen() ? 9 : 10 },
            maxRotation: horizontal ? 0 : (isCompactScreen() ? 28 : 0),
            minRotation: horizontal ? 0 : (isCompactScreen() ? 28 : 0),
        },
    };

    return horizontal ? { x: valueScale, y: categoryScale } : { x: categoryScale, y: valueScale };
}

function getCommonChartOptions({ percent = false, horizontal = false, legendPosition = 'top', categoryCount = 0, dataLabelMinValue = 0, forceDataLabels = false }) {
    return {
        responsive: true,
        maintainAspectRatio: false,
        resizeDelay: 150,
        indexAxis: horizontal ? 'y' : 'x',
        interaction: {
            mode: 'index',
            intersect: false,
        },
        layout: {
            padding: {
                top: 8,
                right: 12,
                left: 4,
                bottom: 4,
            },
        },
        plugins: {
            legend: getLegendOptions(legendPosition),
            datalabels: getDataLabelOptions({
                percent,
                minValue: dataLabelMinValue,
                categoryCount,
                forceDisplay: forceDataLabels,
                horizontal,
            }),
            tooltip: {
                backgroundColor: '#0f172a',
                padding: 10,
            },
        },
        scales: getBarScales({ percent, horizontal }),
    };
}

function buildQuestionAxisLabel(question, index) {
    const wrapped = wrapLabel(
        shortLabel(question.text, isCompactScreen() ? 42 : 34),
        isCompactScreen() ? 14 : 11,
        isCompactScreen() ? 3 : 2
    );
    return [`P${index + 1}`, ...wrapped];
}

