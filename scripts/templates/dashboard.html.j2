// =====================================================================
// DETAIL TABLE
// =====================================================================
function updateDetailTable() {
    const tbody = document.getElementById('detailTableBody');
    const questions = DASHBOARD_DATA.questions;

    // Group by dimension -> variable -> questions
    const dimGroups = {};
    questions.forEach(q => {
        if (!dimGroups[q.dimension]) dimGroups[q.dimension] = {};
        if (!dimGroups[q.dimension][q.variable]) dimGroups[q.dimension][q.variable] = [];
        dimGroups[q.dimension][q.variable].push(q);
    });

    let html = '';
    const dimOrder = ['Respeto', 'Imparcialidad', 'Credibilidad', 'Compa\u00f1erismo', 'Preguntas Abierta'];

    dimOrder.forEach(dim => {
        if (!dimGroups[dim]) return;
        const variables = dimGroups[dim];
        const varNames = Object.keys(variables);
        let dimRowSpan = 0;
        varNames.forEach(v => dimRowSpan += variables[v].length);

        let dimWritten = false;
        varNames.forEach(varName => {
            const qs = variables[varName];
            let varWritten = false;
            qs.forEach(q => {
                const f = calcFavForQuestions(filteredRecords, [q.key]);
                html += '<tr>';

                if (!dimWritten) {
                    html += `<td rowspan="${dimRowSpan}" style="font-weight:700;background:#f8f9fa;vertical-align:middle;">${dim}</td>`;
                    dimWritten = true;
                }

                if (!varWritten) {
                    html += `<td rowspan="${qs.length}" style="font-weight:600;vertical-align:middle;">${varName}</td>`;
                    varWritten = true;
                }

                html += `<td style="font-size:0.78rem;">${shortLabel(q.text, 60)}</td>`;
                html += `<td class="text-center" style="color:${COLORS.favorable};font-weight:700;">${f.fav.toFixed(1)}%</td>`;
                html += `<td class="text-center" style="color:${COLORS.indeciso};font-weight:700;">${f.ind.toFixed(1)}%</td>`;
                html += `<td class="text-center" style="color:${COLORS.desfavorable};font-weight:700;">${f.desf.toFixed(1)}%</td>`;
                html += `<td>
                    <div class="mini-bar-container">
                        <div class="mini-bar" style="width:${f.fav}%;background:${COLORS.favorable};">${f.fav > 8 ? f.fav.toFixed(0) + '%' : ''}</div>
                        <div class="mini-bar" style="width:${f.ind}%;background:${COLORS.indeciso};">${f.ind > 8 ? f.ind.toFixed(0) + '%' : ''}</div>
                        <div class="mini-bar" style="width:${f.desf}%;background:${COLORS.desfavorable};">${f.desf > 8 ? f.desf.toFixed(0) + '%' : ''}</div>
                    </div>
                </td>`;
                html += '</tr>';
            });
        });
    });

    tbody.innerHTML = html;
}

// =====================================================================
// EXPORT CSV
// =====================================================================
function exportCSV() {
    const questions = DASHBOARD_DATA.questions;
    const headers = ['ID', 'Genero', 'Edad', 'Antiguedad', 'Estudios', 'Centro', 'Planta'];
    questions.forEach(q => headers.push(q.text));

    const rows = filteredRecords.map(r => {
        const row = [r.id, r.genero, r.edad, r.antiguedad, r.estudios, r.centro, r.planta];
        questions.forEach(q => row.push(r[q.key]));
        return row.map(v => `"${String(v).replace(/"/g, '""')}"`).join(',');
    });

    const csv = '\uFEFF' + headers.map(h => `"${h}"`).join(',') + '\n' + rows.join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'pulso_cultura_filtrado.csv';
    a.click();
    URL.revokeObjectURL(url);

    Swal.fire({
        icon: 'success',
        title: 'CSV Exportado',
        text: `Se exportaron ${filteredRecords.length} registros filtrados.`,
        timer: 2500,
        showConfirmButton: false,
    });
}
