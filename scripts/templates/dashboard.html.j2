<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pulso Cultura - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <script src="https://unpkg.com/netlify-identity-widget"></script>
    <style>
        :root {
            --favorable: #28a745;
            --indeciso: #ffc107;
            --desfavorable: #dc3545;
            --femenino: #FFB6C1;
            --masculino: #6CA6CD;
            --bg-body: #f0f2f5;
            --card-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        body { background: var(--bg-body); font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; }
        .dashboard-header {
            background: linear-gradient(135deg, #1a237e 0%, #283593 100%);
            color: #fff; padding: 1.2rem 0; margin-bottom: 1.5rem;
        }
        .dashboard-header h1 { font-size: 1.6rem; font-weight: 700; margin: 0; }
        .dashboard-header .subtitle { opacity: 0.85; font-size: 0.9rem; }
        .card { border: none; border-radius: 12px; box-shadow: var(--card-shadow); margin-bottom: 1.2rem; }
        .card-header { background: #fff; border-bottom: 2px solid #e9ecef; border-radius: 12px 12px 0 0 !important; font-weight: 600; }
        .section-title { font-size: 1.1rem; font-weight: 700; color: #1a237e; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 3px solid #1a237e; }
        .kpi-card { text-align: center; padding: 1.5rem; }
        .kpi-number { font-size: 3rem; font-weight: 800; color: #1a237e; }
        .kpi-label { font-size: 0.95rem; color: #6c757d; margin-top: 0.3rem; }
        .filter-section { background: #fff; border-radius: 12px; padding: 1rem 1.2rem; }
        .filter-label { font-size: 0.8rem; font-weight: 600; color: #495057; margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .form-select { border-radius: 8px; border-color: #dee2e6; font-size: 0.875rem; }
        .form-select:focus { border-color: #1a237e; box-shadow: 0 0 0 0.2rem rgba(26,35,126,0.15); }
        .chart-container { position: relative; width: 100%; }
        .chart-container.pie { max-width: 300px; margin: 0 auto; }
        .btn-export { background: #1a237e; border: none; font-size: 0.85rem; border-radius: 8px; }
        .btn-export:hover { background: #283593; }
        .btn-clear { font-size: 0.85rem; border-radius: 8px; }
        .detail-table { font-size: 0.82rem; }
        .detail-table th { background: #1a237e; color: #fff; font-weight: 600; position: sticky; top: 0; }
        .detail-table td { vertical-align: middle; }
        .mini-bar-container { display: flex; height: 22px; border-radius: 4px; overflow: hidden; min-width: 150px; }
        .mini-bar { display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.7rem; font-weight: 600; }
        .filter-divider { border-left: 2px solid #dee2e6; }
        .auth-container { display: flex; gap: 1rem; align-items: center; }
        .user-info { font-size: 0.9rem; color: #fff; }
        .user-name { font-weight: 600; }
        .btn-logout { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4); color: #fff; font-size: 0.85rem; }
        .btn-logout:hover { background: rgba(255,255,255,0.3); color: #fff; }
        .loading-spinner { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999; }
        .loading-spinner.active { display: block; }
        @media (max-width: 768px) {
            .filter-divider { border-left: none; border-top: 2px solid #dee2e6; padding-top: 1rem; margin-top: 1rem; }
            .kpi-number { font-size: 2rem; }
            .auth-container { flex-direction: column; gap: 0.5rem; }
        }
    </style>
</head>
<body>

<!-- Header -->
<div class="dashboard-header">
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="bi bi-bar-chart-fill me-2"></i>Pulso Cultura - Dashboard de Resultados</h1>
                <div class="subtitle">Super de Alimentos S.A. | Encuesta de Clima Organizacional</div>
            </div>
            <div class="auth-container">
                <div class="user-info" id="userInfo" style="display: none;">
                    <span>Usuario: <span class="user-name" id="userName"></span></span>
                </div>
                <button class="btn btn-light btn-export" id="btnExport" onclick="exportCSV()" style="display: none;">
                    <i class="bi bi-download me-1"></i> Exportar CSV
                </button>
                <button class="btn btn-logout" id="btnLogout" onclick="logout()" style="display: none;">
                    <i class="bi bi-box-arrow-right me-1"></i> Salir
                </button>
                <button class="btn btn-light btn-export" id="btnLogin" onclick="showLoginModal()">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Ingresar
                </button>
            </div>
        </div>
    </div>
</div>

<div class="loading-spinner" id="loadingSpinner">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Cargando...</span>
    </div>
</div>

<div class="container-fluid px-4">

    <!-- FILTERS -->
    <div class="card mb-4">
        <div class="card-header d-flex align-items-center">
            <i class="bi bi-funnel-fill me-2 text-primary"></i> Filtros
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Demographic Filters -->
                <div class="col-lg-7">
                    <div class="mb-2" style="font-size:0.85rem;font-weight:700;color:#1a237e;">
                        <i class="bi bi-people-fill me-1"></i> Filtros Demograficos
                    </div>
                    <div class="row g-2">
                        <div class="col-md-3">
                            <div class="filter-label">Genero</div>
                            <select id="filterGenero" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <div class="filter-label">Edad</div>
                            <select id="filterEdad" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <div class="filter-label">Antiguedad</div>
                            <select id="filterAntiguedad" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <div class="filter-label">Estudios Cursados</div>
                            <select id="filterEstudios" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                    </div>
                </div>
                <!-- Area Filters -->
                <div class="col-lg-4 filter-divider ps-lg-4">
                    <div class="mb-2" style="font-size:0.85rem;font-weight:700;color:#1a237e;">
                        <i class="bi bi-building me-1"></i> Filtros de Area
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="filter-label">Centro</div>
                            <select id="filterCentro" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <div class="filter-label">Planta</div>
                            <select id="filterPlanta" class="form-select form-select-sm" onchange="applyFilters()">
                                <option value="">Todos</option>
                            </select>
                        </div>
                    </div>
                </div>
                <!-- Clear button -->
                <div class="col-lg-1 d-flex align-items-end justify-content-end">
                    <button class="btn btn-outline-secondary btn-clear btn-sm w-100" onclick="clearFilters()">
                        <i class="bi bi-x-circle me-1"></i>Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI + PIE -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body kpi-card">
                    <div class="kpi-label"><i class="bi bi-person-check-fill me-1"></i>Total de Encuestados</div>
                    <div class="kpi-number" id="totalEncuestados">0</div>
                    <div class="text-muted" style="font-size:0.8rem;" id="totalSubtext"></div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-pie-chart-fill me-2 text-success"></i>Favorabilidad Global</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <div class="chart-container pie">
                        <canvas id="chartPie"></canvas>
                    </div>
                    <div id="pieStats" class="ms-4" style="font-size:0.9rem;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- SOCIODEMOGRAPHIC -->
    <div class="section-title"><i class="bi bi-person-vcard me-2"></i>Caracterizacion Sociodemografica</div>
    <div class="row mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Genero</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartGenero"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Edad</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartEdad"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Antiguedad</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartAntiguedad"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-header">Estudios Cursados</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartEstudios"></canvas></div></div>
            </div>
        </div>
    </div>

    <!-- SURVEY RESULTS -->
    <div class="section-title"><i class="bi bi-clipboard-data me-2"></i>Resultados de Encuesta</div>

    <!-- Favorability by Question -->
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-bar-chart-steps me-2 text-success"></i>Favorabilidad por Pregunta</div>
        <div class="card-body">
            <div class="chart-container" style="min-height:400px;"><canvas id="chartFavPregunta"></canvas></div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-building me-2 text-primary"></i>Favorabilidad por Centro</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartFavCentro"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-diagram-3 me-2 text-info"></i>Favorabilidad por Planta</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartFavPlanta"></canvas></div></div>
            </div>
        </div>
    </div>

    <!-- DIMENSION & VARIABLE ANALYSIS -->
    <div class="section-title"><i class="bi bi-diagram-2 me-2"></i>Analisis por Dimension y Variable</div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-layers me-2 text-warning"></i>Favorabilidad por Dimension</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartFavDimension"></canvas></div></div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-tags me-2 text-danger"></i>Favorabilidad por Variable</div>
                <div class="card-body"><div class="chart-container"><canvas id="chartFavVariable"></canvas></div></div>
            </div>
        </div>
    </div>

    <!-- Detail Table -->
    <div class="card mb-5">
        <div class="card-header"><i class="bi bi-table me-2 text-secondary"></i>Tabla Detallada: Dimension / Variable / Pregunta</div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height:600px;overflow-y:auto;">
                <table class="table table-hover detail-table mb-0">
                    <thead>
                        <tr>
                            <th>Dimension</th>
                            <th>Variable</th>
                            <th>Pregunta</th>
                            <th style="min-width:100px;">Favorable</th>
                            <th style="min-width:100px;">Indeciso</th>
                            <th style="min-width:100px;">Desfavorable</th>
                            <th style="min-width:200px;">Distribucion</th>
                        </tr>
                    </thead>
                    <tbody id="detailTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<!-- CDN Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
// =====================================================================
// CONFIGURATION
// =====================================================================
const COLORS = {
    favorable: '#28a745',
    indeciso: '#ffc107',
    desfavorable: '#dc3545',
    femenino: '#FFB6C1',
    masculino: '#6CA6CD',
};

// =====================================================================
// GLOBALS
// =====================================================================
let DASHBOARD_DATA = null;
let charts = {};
let filteredRecords = [];
let currentUser = null;

// =====================================================================
// NETLIFY IDENTITY SETUP
// =====================================================================
if (typeof netlifyIdentity !== 'undefined') {
    netlifyIdentity.on('init', (user) => {
        if (!user) {
            showLoginModal();
        } else {
            currentUser = user;
            updateAuthUI(user);
            loadDashboardData();
        }
    });

    netlifyIdentity.on('login', (user) => {
        currentUser = user;
        updateAuthUI(user);
        loadDashboardData();
    });

    netlifyIdentity.on('logout', () => {
        currentUser = null;
        updateAuthUI(null);
        showLoginModal();
    });
}

// =====================================================================
// AUTH FUNCTIONS
// =====================================================================
function updateAuthUI(user) {
    const userInfo = document.getElementById('userInfo');
    const userName = document.getElementById('userName');
    const btnLogin = document.getElementById('btnLogin');
    const btnLogout = document.getElementById('btnLogout');
    const btnExport = document.getElementById('btnExport');

    if (user) {
        userName.textContent = user.user_metadata?.full_name || user.email || 'Usuario';
        userInfo.style.display = 'block';
        btnLogout.style.display = 'block';
        btnExport.style.display = 'block';
        btnLogin.style.display = 'none';
    } else {
        userInfo.style.display = 'none';
        btnLogout.style.display = 'none';
        btnExport.style.display = 'none';
        btnLogin.style.display = 'block';
    }
}

function showLoginModal() {
    if (typeof netlifyIdentity !== 'undefined') {
        netlifyIdentity.open();
    }
}

function logout() {
    if (typeof netlifyIdentity !== 'undefined') {
        netlifyIdentity.logout();
    }
}

// =====================================================================
// DATA LOADING
// =====================================================================
async function loadDashboardData() {
    const loading = document.getElementById('loadingSpinner');
    
    try {
        loading.classList.add('active');
        
        let token = null;
        if (typeof netlifyIdentity !== 'undefined' && currentUser) {
            token = currentUser.token.access_token;
        }
        
        const response = await fetch('/.netlify/functions/dashboard', {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            }
        });

        if (!response.ok) {
            throw new Error(`API error: ${response.status}`);
        }

        const apiData = await response.json();
        
        DASHBOARD_DATA = {
            questions: apiData.questions,
            filterOptions: apiData.filterOptions,
        };

        initializeDashboard();
        
    } catch (error) {
        console.error('Failed to load dashboard data:', error);
        alert('Error cargando datos del dashboard. Por favor, intenta nuevamente.');
    } finally {
        loading.classList.remove('active');
    }
}

function initializeDashboard() {
    if (!DASHBOARD_DATA) return;
    
    Chart.register(ChartDataLabels);
    populateFilters();
    applyFilters();
}

// =====================================================================
// INIT
// =====================================================================
document.addEventListener('DOMContentLoaded', () => {
    if (typeof netlifyIdentity !== 'undefined') {
        netlifyIdentity.init();
    } else {
        console.warn('Netlify Identity not available');
    }
});

function populateFilters() {
    const opts = DASHBOARD_DATA.filterOptions;
    fillSelect('filterGenero', opts.genero);
    fillSelect('filterEdad', opts.edad);
    fillSelect('filterAntiguedad', opts.antiguedad);
    fillSelect('filterEstudios', opts.estudios);
    fillSelect('filterCentro', opts.centro);
    fillSelect('filterPlanta', opts.planta);
}

function fillSelect(id, values) {
    const sel = document.getElementById(id);
    values.forEach(v => {
        const opt = document.createElement('option');
        opt.value = v;
        opt.textContent = v;
        sel.appendChild(opt);
    });
}

// =====================================================================
// FILTERS
// =====================================================================
function applyFilters() {
    const gf = document.getElementById('filterGenero').value;
    const ef = document.getElementById('filterEdad').value;
    const af = document.getElementById('filterAntiguedad').value;
    const esf = document.getElementById('filterEstudios').value;
    const cf = document.getElementById('filterCentro').value;
    const pf = document.getElementById('filterPlanta').value;

    filteredRecords = DASHBOARD_DATA.records.filter(r => {
        if (gf && r.genero !== gf) return false;
        if (ef && r.edad !== ef) return false;
        if (af && r.antiguedad !== af) return false;
        if (esf && r.estudios !== esf) return false;
        if (cf && r.centro !== cf) return false;
        if (pf && r.planta !== pf) return false;
        return true;
    });

    updateAll();
}

function clearFilters() {
    ['filterGenero','filterEdad','filterAntiguedad','filterEstudios','filterCentro','filterPlanta']
        .forEach(id => document.getElementById(id).value = '');
    applyFilters();
}

// =====================================================================
// UPDATE ALL
// =====================================================================
function updateAll() {
    updateTotalCard();
    updatePieChart();
    updateGenderChart();
    updateAgeChart();
    updateSeniorityChart();
    updateEducationChart();
    updateFavByQuestion();
    updateFavByCentro();
    updateFavByPlanta();
    updateFavByDimension();
    updateFavByVariable();
    updateDetailTable();
}

// =====================================================================
// HELPERS
// =====================================================================
function destroyChart(key) {
    if (charts[key]) { charts[key].destroy(); charts[key] = null; }
}

function countByGroup(records, field) {
    const counts = {};
    records.forEach(r => {
        const val = r[field] || 'Sin dato';
        counts[val] = (counts[val] || 0) + 1;
    });
    return counts;
}

function countByGroupGender(records, field, orderedKeys) {
    const fem = {}, masc = {};
    orderedKeys.forEach(k => { fem[k] = 0; masc[k] = 0; });
    records.forEach(r => {
        const val = r[field] || 'Sin dato';
        if (!orderedKeys.includes(val)) return;
        if (r.genero === 'Femenino') fem[val]++;
        else masc[val]++;
    });
    return { fem, masc };
}

function calcFavorability(records) {
    let total = 0, fav = 0, ind = 0, desf = 0;
    const qKeys = DASHBOARD_DATA.questions.map(q => q.key);
    records.forEach(r => {
        qKeys.forEach(k => {
            const v = r[k];
            if (v === 1 || v === 2 || v === 3) {
                total++;
                if (v === 3) fav++;
                else if (v === 2) ind++;
                else desf++;
            }
        });
    });
    if (total === 0) return { fav: 0, ind: 0, desf: 0, total: 0 };
    return {
        fav: (fav / total * 100),
        ind: (ind / total * 100),
        desf: (desf / total * 100),
        total,
    };
}

function calcFavForQuestions(records, questionKeys) {
    let total = 0, fav = 0, ind = 0, desf = 0;
    records.forEach(r => {
        questionKeys.forEach(k => {
            const v = r[k];
            if (v === 1 || v === 2 || v === 3) {
                total++;
                if (v === 3) fav++;
                else if (v === 2) ind++;
                else desf++;
            }
        });
    });
    if (total === 0) return { fav: 0, ind: 0, desf: 0 };
    return {
        fav: (fav / total * 100),
        ind: (ind / total * 100),
        desf: (desf / total * 100),
    };
}

function shortLabel(text, maxLen = 40) {
    if (text.length <= maxLen) return text;
    return text.substring(0, maxLen - 3) + '...';
}

// =====================================================================
// TOTAL CARD
// =====================================================================
function updateTotalCard() {
    document.getElementById('totalEncuestados').textContent = filteredRecords.length;
    const totalAll = DASHBOARD_DATA.records.length;
    const pct = totalAll > 0 ? (filteredRecords.length / totalAll * 100).toFixed(1) : 0;
    document.getElementById('totalSubtext').textContent =
        filteredRecords.length === totalAll ? 'Sin filtros aplicados' : `${pct}% del total (${totalAll})`;
}

// =====================================================================
// PIE CHART
// =====================================================================
function updatePieChart() {
    destroyChart('pie');
    const f = calcFavorability(filteredRecords);
    const ctx = document.getElementById('chartPie').getContext('2d');

    document.getElementById('pieStats').innerHTML = `
        <div class="mb-2"><span style="color:${COLORS.favorable};font-weight:700;">${f.fav.toFixed(1)}%</span> Favorable</div>
        <div class="mb-2"><span style="color:${COLORS.indeciso};font-weight:700;">${f.ind.toFixed(1)}%</span> Indeciso</div>
        <div><span style="color:${COLORS.desfavorable};font-weight:700;">${f.desf.toFixed(1)}%</span> Desfavorable</div>
    `;

    charts.pie = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Favorable', 'Indeciso', 'Desfavorable'],
            datasets: [{
                data: [f.fav, f.ind, f.desf],
                backgroundColor: [COLORS.favorable, COLORS.indeciso, COLORS.desfavorable],
                borderWidth: 2,
                borderColor: '#fff',
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            cutout: '55%',
            plugins: {
                legend: { display: true, position: 'bottom', labels: { font: { size: 11 } } },
                datalabels: {
                    color: '#fff',
                    font: { weight: 'bold', size: 13 },
                    formatter: v => v > 5 ? v.toFixed(1) + '%' : '',
                },
            },
        },
    });
}

// =====================================================================
// GENDER CHART
// =====================================================================
function updateGenderChart() {
    destroyChart('genero');
    const labels = ['Femenino', 'Masculino'];
    const counts = countByGroup(filteredRecords, 'genero');
